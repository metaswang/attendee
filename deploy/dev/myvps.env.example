# Production control-plane env template.
# Copy this file to deploy/production/myvps.env and fill in the real values.

# Core Django
DJANGO_SETTINGS_MODULE=attendee.settings.production
SITE_DOMAIN=10.88.0.2
SITE_BASE_URL=http://10.88.0.2:8100
EXTERNAL_WEBHOOK_SITE_DOMAIN=http://10.88.0.2:8100
DJANGO_SECRET_KEY=replace-me
CREDENTIALS_ENCRYPTION_KEY=replace-me

# Database / Redis
DATABASE_URL=postgresql://postgres:replace-me@db.example.com:5432/postgres?sslmode=require
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db.example.com
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
REDIS_URL=rediss://:replace-me@redis.example.com:6379/5
REDIS_SSL_REQUIREMENTS=required
CSRF_TRUSTED_ORIGINS=http://10.88.0.2:8100
MEETBOT_RUNTIME_API_BASE_URL=https://api.example.com              # Public API facade base URL that runtimes can reach
ATTENDEE_INTERNAL_SERVICE_KEY=replace-me-shared-service-key       # Shared with voxella-api ATTENDEE__INTERNAL_SERVICE_KEY

# Object storage
STORAGE_PROTOCOL=s3
AWS_ENDPOINT_URL=https://example.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_RECORDING_STORAGE_BUCKET_NAME=replace-me   # video recordings (video/ prefix, e.g. voxella-video)
AWS_AUDIO_CHUNK_STORAGE_BUCKET_NAME=replace-me # audio recordings (customer_audio/ prefix, e.g. vox)

# Hybrid meetbot runtime
LAUNCH_BOT_METHOD=hybrid
MEETBOT_RUNTIME_SCHEDULER_ENABLED=true
MEETBOT_VPS_TARGET_ORDER=myvps,myvps3,myvps2
MEETBOT_VPS_SLOT_CAPACITY_JSON={"myvps":2,"myvps3":1,"myvps2":1}
MEETBOT_SCHEDULER_SKIP_VPS=false
MEETBOT_GCP_VM_SLOT_CAPACITY=1
MEETBOT_GCP_VM_SLOT_CAPACITY_BY_RUNTIME_CLASS_FAMILY_JSON={"light":2,"web":1}
MEETBOT_GCP_VM_SLOT_CAPACITY_BY_MACHINE_TYPE_JSON={"e2-standard-2":2,"e2-standard-4":1,"e2-standard-8":1}
MEETBOT_GCP_IDLE_SHUTDOWN_SECONDS=300
MEETBOT_BOT_SLOT_MEMORY_MB=512
GCP_PROJECT_ID=replace-me
GCP_BOT_DEFAULT_REGION=asia-southeast1
GCP_BOT_REGIONS=asia-southeast1,us-central1,europe-west1
GCP_BOT_REGION_ZONES_JSON={"asia-southeast1":["asia-southeast1-b"],"us-central1":["us-central1-a"]}
GCP_BOT_SOURCE_IMAGE_FAMILY=attendee-bot-golden
GCP_BOT_SOURCE_IMAGE_PROJECT=replace-me
GCP_BOT_SUBNETWORK=replace-me
GCP_BOT_MACHINE_TYPE=n2-standard-2
GCP_BOT_BOOT_DISK_GB=30
GCP_BOT_DISK_TYPE=pd-balanced
GCP_BOT_TAGS=attendee-bot,env-prod
GCP_BOT_LABELS_JSON={"environment":"prod"}
GCP_BOT_SERVICE_ACCOUNT_EMAIL=replace-me
GCP_BOT_SERVICE_ACCOUNT_SCOPES=https://www.googleapis.com/auth/cloud-platform
GCP_BOT_QUOTA_METRIC=CPUS
GCP_BOT_REGION_SOFT_CAPS_JSON={"asia-southeast1":32,"us-central1":32,"europe-west1":32}
GCP_RUNTIME_CAPACITY_SYNC_ON_SCHEDULER=true
GOOGLE_APPLICATION_CREDENTIALS=/var/lib/attendee-gcloud/application_default_credentials.json

SAVE_BOT_RESOURCE_SNAPSHOTS=true

# Runtime host / image settings
ATTENDEE_REPO_DIR=/voxella/voxella-attendee
ATTENDEE_CONTAINER_WORKDIR=/attendee
ATTENDEE_REPO_URL=https://github.com/your-org/attendee.git
ATTENDEE_GIT_REF=main
BOT_RUNTIME_IMAGE=asia-southeast1-docker.pkg.dev/replace-me/attendee/attendee-bot-runner@sha256:replace-me
BOT_RUNTIME_ALLOW_BOOTSTRAP=false
GCP_BOT_ALLOW_RUNTIME_BOOTSTRAP=false
