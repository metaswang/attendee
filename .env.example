LAUNCH_BOT_METHOD=gcp-compute-engine
DJANGO_SETTINGS_MODULE=attendee.settings.production

# Django / crypto
DJANGO_SECRET_KEY=placeholder_django_secret_key
CREDENTIALS_ENCRYPTION_KEY=placeholder_credentials_encryption_key

# PostgreSQL
POSTGRES_DB=placeholder_postgres_db
POSTGRES_USER=placeholder_postgres_user
POSTGRES_PASSWORD=placeholder_postgres_password
POSTGRES_HOST=placeholder_postgres_host
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# Redis / Celery
REDIS_URL=redis://placeholder_redis_host:6379/0

# Object storage
STORAGE_PROTOCOL=s3
AWS_ENDPOINT_URL=https://placeholder.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=placeholder_aws_access_key_id
AWS_SECRET_ACCESS_KEY=placeholder_aws_secret_access_key
AWS_RECORDING_STORAGE_BUCKET_NAME=placeholder_recording_bucket

# Google integration secrets
GOOGLE__CLIENT_SECRET=placeholder_google_client_secret
GOOGLE__REDIRECT_BASE=https://placeholder.example.com
GOOGLE__STATE_TTL_SECONDS=600
GOOGLE__INTEGRATION_TOKEN_ENCRYPTION_KEY=placeholder_google_integration_token_encryption_key

# GCP runtime
GCP_PROJECT_ID=placeholder_gcp_project_id
GCP_BOT_DEFAULT_REGION=asia-southeast1
GCP_BOT_REGIONS=asia-southeast1,us-central1,europe-east1,europe-west1
GCP_BOT_REGION_ZONES_JSON={"asia-southeast1":["asia-southeast1-b"],"us-central1":["us-central1-a"]}
GCP_BOT_SOURCE_IMAGE_FAMILY=attendee-bot-golden
GCP_BOT_SOURCE_IMAGE_PROJECT=meetbot-image-v1
GCP_BOT_SUBNETWORK=https://www.googleapis.com/compute/v1/projects/gen-lang-client-0396714319/regions/asia-southeast1/subnetworks/default
GCP_BOT_MACHINE_TYPE=n2-standard-2
GCP_BOT_BOOT_DISK_GB=30
GCP_BOT_DISK_TYPE=pd-balanced
GCP_BOT_TAGS=attendee-bot,env-prod
GCP_BOT_LABELS_JSON={"environment":"prod"}
GCP_BOT_SERVICE_ACCOUNT_EMAIL=
GCP_BOT_SERVICE_ACCOUNT_SCOPES=https://www.googleapis.com/auth/cloud-platform
GCP_BOT_QUOTA_METRIC=CPUS
GCP_BOT_REGION_SOFT_CAPS_JSON={"asia-southeast1":32,"us-central1":32,"europe-east1":32,"europe-west1":32}
GCP_RUNTIME_CAPACITY_SYNC_ON_SCHEDULER=true
