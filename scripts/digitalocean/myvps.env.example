# Core Django
DJANGO_SETTINGS_MODULE=attendee.settings.production
SITE_DOMAIN=attendee.example.com
EXTERNAL_WEBHOOK_SITE_DOMAIN=attendee.example.com
DJANGO_SECRET_KEY=replace-me
CREDENTIALS_ENCRYPTION_KEY=replace-me

# Database / Redis
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db.example.com
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
REDIS_URL=rediss://:replace-me@redis.example.com:6379/5

# Object storage
STORAGE_PROTOCOL=s3
AWS_ENDPOINT_URL=https://example.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_RECORDING_STORAGE_BUCKET_NAME=replace-me

# DigitalOcean bot runtime
LAUNCH_BOT_METHOD=digitalocean-droplet
DROPLET_API_KEY=dop_v1_replace_me
DO_BOT_REGION=sgp1
DO_BOT_SIZE_SLUG=s-4vcpu-8gb
DO_BOT_SNAPSHOT_ID=
DO_BOT_SSH_KEY_IDS=123456,789012
DO_BOT_TAGS=attendee-bot,env-prod
SAVE_BOT_RESOURCE_SNAPSHOTS=true

# Template droplet build inputs
DO_TEMPLATE_DROPLET_NAME=attendee-bot-template
DO_TEMPLATE_BASE_IMAGE=ubuntu-22-04-x64
DO_TEMPLATE_SIZE_SLUG=s-4vcpu-8gb
DO_TEMPLATE_TAGS=attendee-template,env-prod

# Repo / image used on the template droplet
ATTENDEE_REPO_URL=https://github.com/your-org/attendee.git
ATTENDEE_GIT_REF=main
BOT_RUNTIME_IMAGE=attendee-bot-runner:latest
