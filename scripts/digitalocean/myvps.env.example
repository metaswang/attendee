# Core Django
DJANGO_SETTINGS_MODULE=attendee.settings.production
SITE_DOMAIN=10.88.0.2
SITE_BASE_URL=http://10.88.0.2:8100
EXTERNAL_WEBHOOK_SITE_DOMAIN=http://10.88.0.2:8100
DJANGO_SECRET_KEY=replace-me
CREDENTIALS_ENCRYPTION_KEY=replace-me

# Database / Redis
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db.example.com
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
REDIS_URL=rediss://:replace-me@redis.example.com:6379/5
MEETBOT_RUNTIME_API_BASE_URL=https://api.example.com
ATTENDEE_INTERNAL_SERVICE_KEY=replace-me-shared-service-key

# Object storage
STORAGE_PROTOCOL=s3
AWS_ENDPOINT_URL=https://example.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_RECORDING_STORAGE_BUCKET_NAME=replace-me

# Hybrid runtime host
LAUNCH_BOT_METHOD=hybrid
MEETBOT_RUNTIME_HOST_NAME=myvps
MEETBOT_RUNTIME_QUEUE_KEY=meetbot:runtime:commands:myvps
ATTENDEE_REPO_DIR=/voxella/voxella-attendee
ATTENDEE_CONTAINER_WORKDIR=/attendee
BOT_RUNTIME_IMAGE=attendee-bot-runner:latest

# Repo used by host bootstrap / image build
ATTENDEE_REPO_URL=https://github.com/your-org/attendee.git
ATTENDEE_GIT_REF=main
